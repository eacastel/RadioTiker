# Where the server receives scans (your NGINX reverse proxy)
SERVER_URL=https://radio.tiker.es/streamer/api/submit-scan

# Optional: preset a user id (otherwise the app will prompt + persist it)
# USER_ID=my-user-123

# Audio types to include
VALID_AUDIO_EXTENSIONS=.mp3,.flac,.wav,.m4a

# Headless default scan folder (for CLI/headless runs)
LIBRARY_PATH=./Music

# Local file server port
AGENT_PORT=8765

# If you expose your local agent via a tunnel, set it here (optional)
# PUBLIC_BASE_URL=https://your-tunnel.example

# --- Reverse tunnel (SSH) ---
# Enable SSH reverse tunnel to server
# TUNNEL_ENABLE=1
#
# SSH host/user/key
# SSH_HOST=tunnel.radio.tiker.es
# SSH_USER=rtunnel
# SSH_KEY_PATH=/path/to/agent_key
# SSH_PORT=22
#
# Remote port assigned by server for this agent
# REMOTE_PORT=44001
#
# If using reverse tunnel, PUBLIC_BASE_URL should be:
# PUBLIC_BASE_URL=http://127.0.0.1:REMOTE_PORT
